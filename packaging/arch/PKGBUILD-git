# Maintainer: MijSys <https://github.com/mijsys>
pkgname=hyalode-git
pkgver=0.2.2.r0.g0000000
pkgrel=1
pkgdesc="HyaloDE — Modern Wayland Desktop Environment (git version)"
arch=('x86_64' 'aarch64')
url="https://github.com/mijsys/HyaloDE"
license=('MIT')
depends=(
    'gtkmm-4.0'
    'gtk4-layer-shell'
    'lightdm'
    'vte4'
    'gdk-pixbuf2'
    'wayland'
    'nlohmann-json'
    'mako'
    'swww'
    'dex'
    'grim'
    'slurp'
    'wl-clipboard'
    'ttf-font-awesome'
)
makedepends=(
    'cmake'
    'meson'
    'ninja'
    'pkg-config'
    'wayland-protocols'
    'wlr-protocols'
    'git'
)
provides=('hyalode')
conflicts=('hyalode')
source=("${pkgname}::git+https://github.com/mijsys/HyaloDE.git")
sha256sums=('SKIP')

pkgver() {
    cd "${srcdir}/${pkgname}"
    git describe --long --tags 2>/dev/null | sed 's/^v//;s/-/.r/;s/-/./g' \
        || printf "0.2.2.r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "${srcdir}/${pkgname}"

    cmake -S . -B build \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DHYALO_BUILD_GREETER=ON \
        -DHYALO_BUILD_TERMINAL=ON \
        -DHYALO_BUILD_CONTROL_CENTER=ON \
        -DHYALO_BUILD_UPDATE_CENTER=ON \
        -DHYALO_BUILD_SOFTWARE_STORE=ON \
        -DHYALO_BUILD_FILES=ON

    cmake --build build

    meson setup build-compositor compositor/hyalo-compositor \
        --prefix /usr \
        -Dhyalo-session-integration=false
    meson compile -C build-compositor
}

package() {
    cd "${srcdir}/${pkgname}"

    DESTDIR="${pkgdir}" cmake --install build

    # HyaloWM compositor artifacts (vendored in this repo)
    install -Dm755 build-compositor/labwc "${pkgdir}/usr/bin/labwc"
    if [ -f build-compositor/clients/labnag ]; then
        install -Dm755 build-compositor/clients/labnag "${pkgdir}/usr/bin/labnag"
    fi
    install -Dm755 compositor/hyalo-compositor/clients/lab-sensible-terminal \
        "${pkgdir}/usr/bin/lab-sensible-terminal"

    # Runtime libs required by the bundled compositor build
    install -d "${pkgdir}/usr/lib/hyalo"
    install -Dm755 build-compositor/subprojects/seatd/libseat.so.1 \
        "${pkgdir}/usr/lib/hyalo/libseat.so.1"
    ln -sf libseat.so.1 "${pkgdir}/usr/lib/hyalo/libseat.so"
    if [ -f build-compositor/subprojects/libdisplay-info/libdisplay-info.so.0.4.0 ]; then
        install -Dm755 build-compositor/subprojects/libdisplay-info/libdisplay-info.so.0.4.0 \
            "${pkgdir}/usr/lib/hyalo/libdisplay-info.so.0.4.0"
        ln -sf libdisplay-info.so.0.4.0 "${pkgdir}/usr/lib/hyalo/libdisplay-info.so.4"
        ln -sf libdisplay-info.so.4 "${pkgdir}/usr/lib/hyalo/libdisplay-info.so"
    fi
    if [ -f build-compositor/subprojects/libliftoff/libliftoff.so.0.6.0 ]; then
        install -Dm755 build-compositor/subprojects/libliftoff/libliftoff.so.0.6.0 \
            "${pkgdir}/usr/lib/hyalo/libliftoff.so.0.6.0"
        ln -sf libliftoff.so.0.6.0 "${pkgdir}/usr/lib/hyalo/libliftoff.so.0"
        ln -sf libliftoff.so.0 "${pkgdir}/usr/lib/hyalo/libliftoff.so"
    fi

    install -Dm644 compositor/hyalo-compositor/data/labwc-portals.conf \
        "${pkgdir}/usr/share/xdg-desktop-portal/labwc-portals.conf"
    install -Dm644 compositor/hyalo-compositor/data/labwc-symbolic.svg \
        "${pkgdir}/usr/share/icons/hicolor/scalable/apps/labwc-symbolic.svg"
    install -Dm644 compositor/hyalo-compositor/data/labwc.svg \
        "${pkgdir}/usr/share/icons/hicolor/scalable/apps/labwc.svg"

    # Session desktop entry
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/wayland-sessions/hyalo.desktop" <<EOF
[Desktop Entry]
Name=HyaloDE
Comment=HyaloDE Wayland session
Exec=/usr/libexec/hyalo/hyalo-session
Icon=hyalo
Type=Application
DesktopNames=HyaloDE;HyaloWM;wlroots
EOF

    # LightDM greeter config
    install -Dm644 apps/hyalo-greeter/data/lightdm-hyalo-greeter.conf \
        "${pkgdir}/etc/lightdm/lightdm.conf.d/50-hyalo-greeter.conf"

    # LightDM greeter desktop entry
    install -Dm644 apps/hyalo-greeter/data/hyalo-greeter.desktop \
        "${pkgdir}/usr/share/xgreeters/hyalo-greeter.desktop"

    # labwc config
    install -Dm644 config/labwc/rc.xml "${pkgdir}/usr/share/hyalo/labwc/rc.xml"
    install -Dm755 config/labwc/hyalo-screenshot "${pkgdir}/usr/bin/hyalo-screenshot"
    install -Dm755 config/labwc/hyalo-wallpaperd "${pkgdir}/usr/bin/hyalo-wallpaperd"
    install -Dm755 config/labwc/hyalo-driver-manager "${pkgdir}/usr/bin/hyalo-driver-manager"

    # Mako notification config
    install -Dm644 config/mako/config "${pkgdir}/usr/share/hyalo/mako/config"

    # Window decoration theme
    install -Dm644 config/labwc/themes/HyaloOS/openbox-3/themerc \
        "${pkgdir}/usr/share/themes/HyaloOS/openbox-3/themerc"
    for svg_file in config/labwc/themes/HyaloOS/labwc/*.svg; do
        [ -f "$svg_file" ] || continue
        install -Dm644 "$svg_file" \
            "${pkgdir}/usr/share/themes/HyaloOS/labwc/$(basename "$svg_file")"
    done

    # Session wrapper (same as in stable PKGBUILD)
    install -Dm755 /dev/stdin "${pkgdir}/usr/libexec/hyalo/hyalo-session" <<'SESSIONEOF'
#!/bin/sh
set -eu
PREFIX="/usr"
PANEL_BIN="$PREFIX/bin/hyalo-panel"
WALLPAPER_DAEMON_BIN="$PREFIX/bin/hyalo-wallpaperd"
COMPOSITOR_BIN="$PREFIX/bin/labwc"
RUNTIME_LIB_DIR="$PREFIX/lib/hyalo"
LABWC_CONFIG_DIR="$PREFIX/share/hyalo/labwc"
MAKO_DEFAULT_CONFIG="$PREFIX/share/hyalo/mako/config"

[ -d "$RUNTIME_LIB_DIR" ] && export LD_LIBRARY_PATH="$RUNTIME_LIB_DIR${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
[ -n "${XDG_DATA_DIRS:-}" ] && export XDG_DATA_DIRS="$PREFIX/share:${XDG_DATA_DIRS}" || export XDG_DATA_DIRS="$PREFIX/share:/usr/local/share:/usr/share"
[ -z "${GTK_ICON_THEME:-}" ] && export GTK_ICON_THEME="${HYALO_ICON_THEME:-hyalo-icons}"
[ -z "${GSK_RENDERER:-}" ] && export GSK_RENDERER="gl"
[ -z "${GDK_DISABLE:-}" ] && export GDK_DISABLE="vulkan"

if [ -n "${XDG_CURRENT_DESKTOP:-}" ]; then
    export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP}:HyaloDE"
else
    export XDG_CURRENT_DESKTOP="HyaloDE"
fi
export XDG_SESSION_DESKTOP="HyaloDE"

SESSION_STARTUP='
PANEL_LOG_TARGET="/dev/null"
if [ "${HYALO_PANEL_LOG:-0}" = "1" ]; then
    PANEL_LOG_DIR="${XDG_RUNTIME_DIR:-/tmp}/hyalo"; mkdir -p "$PANEL_LOG_DIR"
    PANEL_LOG_FILE="$PANEL_LOG_DIR/panel.log"
    PANEL_LOG_TARGET="$PANEL_LOG_FILE"
fi
if [ -x "'"$PANEL_BIN"'" ]; then
    ( delay=1; while :; do "'"$PANEL_BIN"'" >>"$PANEL_LOG_TARGET" 2>&1; ec=$?; sleep "$delay"; [ "$delay" -lt 8 ] && delay=$((delay * 2)); done ) &
fi
command -v mako >/dev/null 2>&1 && ! pgrep -xu "$(id -u)" mako >/dev/null 2>&1 && mako >/dev/null 2>&1 &
command -v swww-daemon >/dev/null 2>&1 && ! swww query >/dev/null 2>&1 && swww-daemon >/dev/null 2>&1 &
[ -x "'"$WALLPAPER_DAEMON_BIN"'" ] && HYALO_WALLPAPER_BACKEND="${HYALO_WALLPAPER_BACKEND:-auto}" "'"$WALLPAPER_DAEMON_BIN"'" --daemon >/dev/null 2>&1 &
command -v dex >/dev/null 2>&1 && dex -a -e HyaloDE >/dev/null 2>&1 &
'

if [ -x "$COMPOSITOR_BIN" ]; then
    exec "$COMPOSITOR_BIN" -C "$LABWC_CONFIG_DIR" -m -s "sh -lc '"'"'$SESSION_STARTUP'"'"'" "$@"
fi
exec labwc -C "$LABWC_CONFIG_DIR" -m -s "sh -lc '"'"'$SESSION_STARTUP'"'"'" "$@"
SESSIONEOF

    if [ -f LICENSE ]; then
        install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    fi

    if [ -f compositor/hyalo-compositor/LICENSE ]; then
        install -Dm644 compositor/hyalo-compositor/LICENSE \
            "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-labwc"
    fi
}
